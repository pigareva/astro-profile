---
// DE Datenschutz page (/datenschutz).
// Content: src/content/de/datenschutz.md via 'pages' Content Collection.
import BaseLayout from '@/layouts/BaseLayout.astro';
import Prose from '@/components/Prose.astro';
import { getEntry, render } from 'astro:content';
import { useTranslations } from '@/i18n/ui';

const t = useTranslations('de', 'datenschutzPage');
const entry = await getEntry('pages', 'de/datenschutz');
if (!entry) throw new Error('Content not found: de/datenschutz.md');
const { Content } = await render(entry);
---

<BaseLayout pageTitle={t('pageTitle')} pageDescription={t('pageDescription')}>
  <Prose>
    <Content />
  </Prose>
</BaseLayout>
