---
import Heading from '@/components/Heading.astro';
import SkillCard from '@/components/SkillCard.astro';
import { buttonVariants } from '@/components/ui/button';
import type { LanguageCode } from '@/i18n/ui';
import { Calendar, Phone, Mail } from 'lucide-react';
import { FaLinkedinIn } from 'react-icons/fa';

import heroImage from '@/assets/user-hero.webp';
import { Image } from 'astro:assets';
import FeaturedProjectPreview from '../components/FeaturedProjectPreview.astro';
import type { TranslatedProject, TranslatedSkill } from '../type';

export type Props = {
  lang: LanguageCode;
  projects: Array<TranslatedProject>;
  skills: Array<TranslatedSkill>;
  heroGreeting: string;
  heroSubtitlePart1: string;
  heroSubtitlePart2: string;
  heroName: string;
  heroIntroduction: string;
  heroViewWorkButton: string;
  heroContactButton: string;
  imageNotAvailable: string;
  featuredProjectsTitle: string;
  featuredProjectsDescription: string;
  mySkillsTitle: string;
  mySkillsDescription: string;
  projectPreviewCtaText: string; // Added for specific project CTA
  exchangeTitle: string;
  exchangeDescription: string;
};

const {
  lang,
  projects,
  skills,
  heroGreeting,
  heroSubtitlePart1,
  heroSubtitlePart2,
  heroName,
  heroIntroduction,
  heroViewWorkButton,
  heroContactButton,
  imageNotAvailable,
  featuredProjectsTitle,
  featuredProjectsDescription,
  mySkillsTitle,
  mySkillsDescription,
  projectPreviewCtaText,
  exchangeTitle,
  exchangeDescription,
} = Astro.props;
---

<section class="py-12 md:py-16">
  <div class="grid md:grid-cols-2 gap-12 items-center justify-between">
    {/* Hero Text Column */}
    <div class="text-center md:text-left gorw">
      <h1
        class="text-4xl md:text-5xl lg:text-6xl font-bold tracking-tight mb-4"
      >
        {heroGreeting}
      </h1>
      <p class="text-2xl md:text-3xl font-medium text-muted-foreground mb-2">
        <span>{heroSubtitlePart1}</span>
        {heroSubtitlePart2 && <><span class="text-primary"> | </span><span>{heroSubtitlePart2}</span></>}
      </p>
      <p class="text-lg text-muted-foreground mb-8">
        <strong>{heroName}</strong> {heroIntroduction}
      </p>
      <div
        class="flex flex-col sm:flex-row gap-4 justify-center md:justify-start"
      >
        {/* <a
          href="/projects"
          class={buttonVariants({ variant: 'default', size: 'lg' })}
        >
          <Dumbbell className="mr-2 size-4" />
          {heroViewWorkButton}
        </a> */}
        <a
          href="#austausch"
          class={buttonVariants({ variant: 'outline', size: 'lg' })}
        >
          <Calendar className="mr-2 size-4" />
          {heroContactButton}
        </a>
      </div>
    </div>

    {/* Hero Image (Placeholder for now) */}
    <div class="flex md:justify-end">
      <div
        class="md:w-[240px] md:h-[240px] w-full aspect-square bg-muted rounded-lg shadow-xl overflow-hidden"
      >
        <Image
          src={heroImage}
          alt={'User profile image'}
          width={240}
          height={240}
          densities={[1, 1.5, 2]}
          quality="high"
          class="h-full w-full object-cover"
        />
      </div>
    </div>
  </div>
</section>

{/* Featured Projects Section — commented out, restore when ready */}
{/* <section id="projects" class="py-12 md:py-16 bg-muted/20 dark:bg-muted/10">
  <Heading
    title={featuredProjectsTitle}
    description={featuredProjectsDescription}
    className="flex flex-col items-center"
  />

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
    {
      projects.slice(0, 3).map((project: TranslatedProject) => {
        return (
          <FeaturedProjectPreview
            lang={lang}
            slug={project.slug}
            title={project.title}
            imageUrl={project.imageUrl}
            imageAltText={project.imageAltText}
            ctaText={projectPreviewCtaText}
          />
        );
      })
    }
  </div>
</section> */}

{/* Skills Section */}
<section id="skills" class="py-12 md:py-16 bg-muted/20 dark:bg-muted/10">
  <div class="container mx-auto px-4">
    <Heading
      title={mySkillsTitle}
      description={mySkillsDescription}
      className="flex flex-col items-center"
    />
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      {
        skills.map((skill) => (
          <SkillCard
            title={skill.title}
            description={skill.description}
            iconName={skill.iconName}
            technologies={skill.technologies}
          />
        ))
      }
    </div>
  </div>
</section>


<section id="austausch" class="py-12 md:py-16">
  <div class="container mx-auto px-4">
    <Heading
      title={exchangeTitle}
      description={exchangeDescription}
      className="flex flex-col items-center"
    />

    <div class="flex flex-wrap justify-center gap-6">
      <a
        href="tel:+4915255921435"
        class="flex items-center gap-3 text-muted-foreground hover:text-primary transition-colors duration-200"
      >
        <span class="inline-flex items-center justify-center p-2 bg-primary/10 rounded-lg">
          <Phone className="size-4 text-primary" />
        </span>
        <span class="text-sm font-medium">+49 152 5592 1435</span>
      </a>

      <a
        href="mailto:olga@pigareva.de"
        class="flex items-center gap-3 text-muted-foreground hover:text-primary transition-colors duration-200"
      >
        <span class="inline-flex items-center justify-center p-2 bg-primary/10 rounded-lg">
          <Mail className="size-4 text-primary" />
        </span>
        <span class="text-sm font-medium">olga@pigareva.de</span>
      </a>

      <a
        href="https://www.linkedin.com/in/olgapigareva/"
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-3 text-muted-foreground hover:text-primary transition-colors duration-200"
      >
        <span class="inline-flex items-center justify-center p-2 bg-primary/10 rounded-lg">
          <FaLinkedinIn className="size-4 text-primary" />
        </span>
        <span class="text-sm font-medium">LinkedIn</span>
      </a>
    </div>
  </div>
</section>
